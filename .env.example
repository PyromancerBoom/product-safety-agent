# --- Google Gemini / Vertex (pick one path) ---
# API key path (simplest for local quickstart): set GOOGLE_API_KEY and comment out
# the Vertex block below (GOOGLE_GENAI_USE_VERTEXAI, GOOGLE_CLOUD_*).
# GOOGLE_API_KEY=

# Vertex AI path (common for hackathon GCP credits):
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=<YOUR_PROJECT_NAME>
GOOGLE_CLOUD_LOCATION=us-central1

# Model override (optional)
# GEMINI_MODEL=gemini-2.5-flash

# --- Phoenix Cloud (phoenix.otel.register — see get-started-tracing) ---
# Create a Phoenix API key at app.phoenix.arize.com (format px_live_...), not an Arize AX key.
PHOENIX_API_KEY=
# REQUIRED for Phoenix Cloud: copy Hostname from Phoenix → Settings (includes /s/<space>).
# Do not use https://app.phoenix.arize.com alone — OTLP will 401.
PHOENIX_COLLECTOR_ENDPOINT=
# Example: https://app.phoenix.arize.com/s/my-team-space (no /v1/traces suffix; the app adds it).
# Also accepted: PHOENIX_BASE_URL, or OTEL_EXPORTER_OTLP_ENDPOINT (base URL only).
# Escape hatch only if you truly ingest at the bare cloud host: PHOENIX_CLOUD_ALLOW_LEGACY_ROOT=1
# Project name in Phoenix (resource attribute openinference.project.name)
PHOENIX_PROJECT_NAME=shopsafe
# Extra OTLP headers if needed: PHOENIX_CLIENT_HEADERS (see Phoenix docs).

# --- Exa web search (required — the agent needs live internet) ---
# Create a key at https://dashboard.exa.ai
EXA_API_KEY=

# --- Gemini CLI MCP (optional; also set in your shell for npx child processes) ---
# export PHOENIX_API_KEY=...

# --- GROQ (optional provider for testing without Gemini rate limits)
GROQ_API_KEY=
# Set USE_GROQ=1 to route all LLM calls through Groq instead of Gemini
# USE_GROQ=1
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Pipeline tuning (all optional, these are the defaults) ---
# PLANNER_MODEL=gemini-2.5-flash
# VERDICT_MODEL=gemini-2.5-flash
# JUDGE_MODEL=gemini-2.5-flash
# MAX_REFINEMENT_PASSES=2
# MAX_PLANNED_QUERIES=3
# EXA_NUM_RESULTS=5
# EXA_SNIPPET_CHARS=800